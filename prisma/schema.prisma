generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  checking
  savings
  credit
  investment
  cash
}

enum CategoryType {
  income
  expense
  transfer
}

enum BudgetPeriod {
  monthly
  yearly
  weekly
}

enum InvestmentType {
  stock
  crypto
  etf
  mutual_fund
  bond
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String?
  email        String    @unique
  passwordHash String
  isAdmin   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  accounts         Account[]
  transactions     Transaction[]
  goals            Goal[]
  budgets          Budget[]
  investments      Investment[]
  categories       Category[]
  hiddenCategories HiddenCategory[]
}

model Account {
  id         String      @id @default(uuid()) @db.Uuid
  name       String
  type       AccountType
  balance    String      // Encrypted AES-256-GCM hex
  currency   String      @default("USD")
  color      String      @default("#6366f1")
  userId     String     @map("user_id") @db.Uuid
  isArchived Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  transactions Transaction[]
  investments  Investment[]
  goals        Goal[]
}

model Transaction {
  id           String       @id @default(uuid()) @db.Uuid
  accountId    String       @db.Uuid
  categoryId   String       @db.Uuid
  amount       String       // Encrypted AES-256-GCM hex (includes sign)
  date         DateTime
  description  String       // Encrypted AES-256-GCM hex
  userId       String       @map("user_id") @db.Uuid
  isReconciled Boolean      @default(false)
  isArchived   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  account  Account  @relation(fields: [accountId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
}

model Category {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  type      CategoryType
  icon      String       @default("📦")
  color     String       @default("#6b7280")
  userId   String?   @map("user_id") @db.Uuid
  isBuiltIn Boolean   @default(false)
  createdAt DateTime  @default(now())

  user             User?             @relation(fields: [userId], references: [id])
  transactions     Transaction[]
  budgets          Budget[]
  hiddenBy         HiddenCategory[]
}

model Budget {
  id         String       @id @default(uuid()) @db.Uuid
  categoryId String       @db.Uuid
  amount     Float
  period     BudgetPeriod
  startDate  DateTime
  endDate    DateTime?
  userId   String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
}

model Goal {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  accountId     String?   @db.Uuid
  icon          String    @default("🎯")
  color         String    @default("#6366f1")
  userId   String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  account Account? @relation(fields: [accountId], references: [id])
}

model Investment {
  id            String         @id @default(uuid()) @db.Uuid
  accountId     String         @db.Uuid
  name          String
  type          InvestmentType
  shares        Float
  purchasePrice String         // Encrypted AES-256-GCM hex
  currentPrice  String         // Encrypted AES-256-GCM hex
  currency      String         @default("USD")
  userId   String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  account Account @relation(fields: [accountId], references: [id])
}

model HiddenCategory {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId])
  @@map("hidden_categories")
}
